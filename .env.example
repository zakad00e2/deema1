# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: API key used by the Vercel contact function to send emails.
RESEND_API_KEY="re_A1b9sgiU_FZekKiR2UuqSjYJJDbycZowF"

# CONTACT_EMAIL_TO: Inbox that should receive contact form submissions.
CONTACT_EMAIL_TO="Leaveanathr@gmail.com"

# CONTACT_EMAIL_FROM: Verified sender used by Resend.
# For testing you can keep onboarding@resend.dev. For production, use a verified domain.
CONTACT_EMAIL_FROM="Athr Contact <onboarding@resend.dev>"

# CONTACT_EMAIL_REPLY_TO: Optional fixed reply-to address.
# Usually leave this unset so replies go to the sender's email from the contact form.

# CONTACT_SITE_URL: Optional site URL included in the email body.
CONTACT_SITE_URL="https://your-domain.com"
